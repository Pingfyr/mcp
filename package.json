{
  "name": "@pingfyr/mcp",
  "version": "0.4.0",
  "description": "MCP server for Pingfyr — schedule reminders via email, webhook, Slack, Discord, Telegram, OpenClaw, or Google Calendar.",
  "author": "Pingfyr <support@pingfyr.com>",
  "homepage": "https://pingfyr.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pingfyr/mcp.git"
  },
  "main": "dist/index.js",
  "bin": {
    "pingfyr-mcp": "bin/pingfyr-mcp.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "echo 'Publish only bin/ — no build needed'"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "reminders",
    "ai-agents",
    "claude",
    "pingfyr"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mcp-remote": "0.1.38",
    "zod": "^3.25.0"
  },
  "bundledDependencies": [
    "mcp-remote"
  ],
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
